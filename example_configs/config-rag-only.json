{
  // RAG-only configuration with size limits
  "repo_path": null,
  
  "tools": {
    "rag": {
      "enabled": true,
      "index_dir": "/tmp/rag-{hash}",
      
      "limits": {
        "max_index_size_mb": 50,
        "max_files": 500,
        "max_chunks": 10000,
        "max_file_size_kb": 512,
        "truncate_size_kb": 128
      },
      
      "priority": {
        "dirs": ["src/", "lib/"],
        "exclude_dirs": [],
        "extensions": []
      }
    },
    "semantic": {
      "enabled": false
    }
  }
}
