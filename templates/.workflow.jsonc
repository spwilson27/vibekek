{
  // Enable Serena MCP server integration for agent code intelligence.
  // When true, workflow seeds each worktree with a Serena cache and rebuilds
  // it after each successful merge so agents have up-to-date code search.
  "serena": true,

  // Enable RAG MCP server integration for AI agents.
  // When true (default), the workflow automatically:
  //   1. Starts a RAG MCP server in each cloned repository
  //   2. Injects RAG CLI help text into every agent prompt
  // This provides agents with powerful code search capabilities including:
  //   - Natural language RAG search ("how does auth work?")
  //   - Semantic symbol search (definitions, references)
  //   - Call hierarchy analysis (callers/callees)
  // Set to false to disable RAG integration and reduce overhead.
  "rag": true,

  // AI CLI backend: "gemini", "claude", "opencode", "copilot", "cline", "aider", "codex", or "qwen"
  // "backend": "gemini",

  // Model name passed through to the AI CLI via --model (optional).
  // "model": "claude-sonnet-4-5-20250514",

  // Disable sandbox violation checks (default: false).
  // "ignore_sandbox": false,

  // Timeout in seconds per AI agent invocation (default: 600 = 10m).
  // "timeout": 600,

  // Max retry attempts per phase on failure (default: 3).
  // "retries": 3,

  // Soft timeout in seconds for Qwen sessions (default: 480 = 8m).
  // When reached, the session is interrupted via SIGINT and resumed
  // with a "finish up" prompt using --resume.  Set to null to disable.
  // "soft_timeout": 480,

  // Maximum prompt size in words for phases that aggregate task content
  // (e.g. cross-phase review, task reordering).  Reduce for models with
  // smaller context windows.  Default: 126000 (~128k token estimate).
  // "context_limit": 126000,

  // Name of the integration/dev branch (default: "dev").
  // "dev_branch": "dev",

  // Git remote used as the single source of truth for clones and pushes
  // (default: "origin").  Change this if your pivot remote has a different
  // name, e.g. "github" or "upstream".
  // "pivot_remote": "origin",

  // Optional: GitHub repository (owner/repo) used by `./do ci` for remote checks.
  // "github_repo": "owner/repo",

  // Multi-agent pool for `workflow run`.  When defined, the scheduler
  // distributes tasks across these agents instead of using a single --backend.
  // Passing --backend on the CLI overrides this section entirely.
  //
  // Each agent entry supports the following fields:
  //   name        (required) Human-readable label shown in logs and the dashboard.
  //   backend     (required) AI CLI to invoke: "gemini", "claude", "opencode",
  //                          "copilot", "cline", "aider", "codex", or "qwen".
  //   user        (required) OS user to run the CLI as.  The command is prefixed
  //                          with `sudo -u <user> --set-home --` so that the
  //                          target user's config files (API keys, CLI settings)
  //                          are used.  Set to the current user to skip sudo.
  //   parallel    (optional) Max concurrent jobs from this agent.  Default: 1.
  //   priority    (optional) Scheduling preference — lower value = preferred first.
  //                          Agents with the same priority are tried round-robin
  //                          by available capacity.  Default: 1.
  //   quota-time  (optional) Seconds to suppress this agent after a quota-exceeded
  //                          message is detected in its output.  Default: 60.
  //   spawn_rate  (optional) Seconds to wait between spawning new agents from this pool.
  //                          Default: 0.0.
  //   model            (optional) Model name forwarded to the CLI via --model.
  //                               Leave unset to use the CLI's own default.
  //   cargo-target-dir (optional) Absolute path for the Cargo build cache
  //                               (sets target-dir in .cargo/config.toml before
  //                               each agent invocation).  Use per-user paths
  //                               (e.g. "/tmp/axel-build-sub") to prevent
  //                               cross-user permission conflicts when different
  //                               agents run as different OS users.
  //   steps       (optional) List of workflow steps this agent may handle.
  //                          Allowed values: "develop", "review", "merge", "all".
  //                          "all" (the default) matches every step.  Use a
  //                          specific list to pin an agent to certain phases,
  //                          e.g. a fast model for review and a powerful one
  //                          for development.
  //
  // "agents": [
  //   {
  //     "name":       "claude-dev",
  //     "backend":    "claude",
  //     "user":       "mrwilson",
  //     "parallel":   3,
  //     "priority":   1,
  //     "quota-time": 60,
  //     "spawn_rate": 0.5,
  //     "steps":      ["develop", "merge"]
  //   },
  //   {
  //     "name":       "gemini-flash-review",
  //     "backend":    "gemini",
  //     "model":      "gemini-2.5-flash",
  //     "user":       "subnat",
  //     "parallel":   5,
  //     "priority":   1,
  //     "quota-time": 60,
  //     "spawn_rate": 2.0,
  //     "steps":      ["review"]
  //   },
  //   {
  //     "name":       "gemini-fallback",
  //     "backend":    "gemini",
  //     "user":       "mrwilson",
  //     "parallel":   2,
  //     "priority":   2,
  //     "quota-time": 120,
  //     "spawn_rate": 1.0,
  //     "steps":      ["all"]
  //   }
  // ]
}

// ─── Docker Configuration (Optional) ─────────────────────────────────────────
// When defined, all workflow steps (implementation, review, presubmit, commit,
// merge) run inside a Docker container. The container is started once per task,
// git-clones the repo from the pivot remote, and pushes changes back after
// validation.
//
// The template Dockerfile (.tools/templates/Dockerfile) uses build arguments
// for the non-root user configuration:
//   - USERNAME (default: weaver) - the non-root user for AI CLI tools
//   - USER_UID (default: 1000) - the UID for the non-root user
//
// AI CLIs (Claude, Gemini, Qwen) refuse --dangerously-skip-permissions when
// running as root for security reasons, so a non-root user is required.
//
// Build your image with:
//   docker build --build-arg USERNAME=username --build-arg USER_UID=1000 -t <image>:<tag> .
//
// Example docker config:
//
// "docker": {
//   "image": "weaver-reloaded:dev",
//   "copy_files": [
//     { "src": "/home/<user>/.claude.json", "dest": "/home/username/.claude.json" },
//     { "src": "/home/<user>/.gemini/oauth_creds.json", "dest": "/home/username/.gemini/oauth_creds.json" },
//     { "src": "/home/<user>/.gemini/settings.json", "dest": "/home/username/.gemini/settings.json" },
//     { "src": "/home/<user>/.qwen/settings.json", "dest": "/home/username/.qwen/settings.json" },
//     { "src": "/home/<user>/.gitconfig", "dest": "/home/username/.gitconfig" },
//     { "src": "/home/<user>/.git-credentials", "dest": "/home/username/.git-credentials" }
//   ]
// },
//
// Per-agent docker overrides are also supported. Agent-level copy_files will
// merge with the global config (agent values win for conflicting paths):
//
// "agents": [
//   {
//     "name": "gemini-dev",
//     "backend": "gemini",
//     "user": "mrwilson",
//     "docker": {
//       "image": "weaver-reloaded:dev",
//       "copy_files": [
//         { "src": "/home/mrwilson/.gemini/oauth_creds.json", "dest": "/home/weaver/.gemini/oauth_creds.json" }
//       ]
//     }
//   }
// ]
